{
  "manifest_version": 3,
  "name": "Feature Flags Manager",
  "version": "1.0.0",
  "description": "Easily view, toggle, and apply feature flags via the URL query string on any website, using a simple popup UI instead of editing the URL by hand.",
  "author": "Muhammad Zoabi",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Feature Flags Manager",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["tabs", "storage"]
}
