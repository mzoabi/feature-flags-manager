{
  "manifest_version": 3,
  "name": "Feature Flags Manager",
  "version": "1.0.0",
  "description": "View, edit, and apply URL query feature flags on any http/https page from a simple popup UI.",
  "author": "Muhammad Zoabi",
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "Feature Flags Manager",
    "default_icon": {
      "16": "src/icons/icon16.png",
      "32": "src/icons/icon32.png",
      "48": "src/icons/icon48.png",
      "128": "src/icons/icon128.png"
    }
  },
  "icons": {
    "16": "src/icons/icon16.png",
    "32": "src/icons/icon32.png",
    "48": "src/icons/icon48.png",
    "128": "src/icons/icon128.png"
  },
  "permissions": ["tabs", "storage"]
}
